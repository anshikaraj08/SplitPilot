{
  "name": "splitpilot",
  "version": "1.0.0",
  "private": true,
  "description": "SplitPilot shared expenses app for the Spreetail assignment.",
  "type": "module",
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "db:setup": "npm run db:setup --workspace server",
    "test": "npm run test --workspace server",
    "build": "npm run build --workspace client"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
